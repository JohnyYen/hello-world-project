{
  "name": "hello-world-project",
  "version": "1.0.0",
  "description": "Hello World Project - Multi-platform educational ecosystem",
  "private": true,
  "directories": {
    "doc": "docs"
  },
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "docker compose -f infraestructure/docker/docker-compose.dev.yml up",
    "dev:backend": "cd apps/backend && poetry run fastapi dev src/main.py --reload",
    "dev:frontend": "cd apps/frontend && pnpm dev",
    "dev:frontend:prod": "cd apps/frontend && pnpm build && pnpm start",
    "generate:api-client": "bash scripts/generate-api-client.sh",
    "docker:up": "docker compose -f infraestructure/docker/docker-compose.dev.yml up",
    "docker:down": "docker compose -f infraestructure/docker/docker-compose.dev.yml down",
    "docker:logs": "docker compose -f infraestructure/docker/docker-compose.dev.yml logs -f"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JohnyYen/hello-world-project.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/JohnyYen/hello-world-project/issues"
  },
  "homepage": "https://github.com/JohnyYen/hello-world-project#readme",
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.30.0"
  }
}
