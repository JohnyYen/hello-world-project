# PostgreSQL Configuration
POSTGRES_USER=hwp_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=hwp_db

# Database URL (async for SQLAlchemy 2.0)
DATABASE_URL=postgresql+asyncpg://hwp_user:hwp_password@postgresql_db:5432/hwp_db

# Backend Security Configuration
BACKEND_SECRET_KEY=change_me_in_production
BACKEND_ALGORITHM=HS256
BACKEND_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
