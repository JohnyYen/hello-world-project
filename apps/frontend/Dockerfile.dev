# Frontend Dockerfile.dev for pnpm monorepo
FROM node:20-alpine

# Install pnpm and curl for healthcheck
RUN npm install -g pnpm && apk add --no-cache curl

WORKDIR /app

# Copy root workspace files first (for dependency resolution)
COPY pnpm-workspace.yaml ./
COPY package.json ./package.json
COPY pnpm-lock.yaml ./

# Copy frontend app
COPY apps/frontend/package.json ./apps/frontend/package.json
COPY apps/frontend/pnpm-lock.yaml ./apps/frontend/pnpm-lock.yaml
COPY apps/frontend/ ./apps/frontend/

# Install dependencies
RUN pnpm install

# Move to frontend directory and start
WORKDIR /app/apps/frontend

CMD ["pnpm", "run", "dev"]