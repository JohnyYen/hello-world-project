# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./test.db

# Security Configuration
# ⚠️ IMPORTANT: Generate a secure key with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=YOUR_SECURE_SECRET_KEY_HERE_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=3600

# Debug mode - set to 'true' only for development, never in production!
DEBUG=false

# SQLAlchemy echo mode - logs all SQL queries (development only)
# DB_ECHO=true

# PostgreSQL Example (uncomment and modify if using PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/database_name